{
  "version": 2,
  "functions": {
    "artifacts/api-server/api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/artifacts/api-server/api/index.ts" }
  ],
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/orbitdesk/dist",
  "env": {
    "NODE_ENV": "production"
  }
}
