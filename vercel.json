{
  "version": 2,
  "buildCommand": "pnpm install && pnpm --filter @workspace/orbitdesk run build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "artifacts/orbitdesk/dist/public",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@3",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/imap-poll",
      "schedule": "*/2 * * * *"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
