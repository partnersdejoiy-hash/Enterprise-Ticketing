{
  "version": 2,
  "buildCommand": "pnpm install && cd lib/db && npx tsc -p tsconfig.json && cd ../.. && pnpm --filter @workspace/orbitdesk run build",
  "outputDirectory": "artifacts/orbitdesk/dist",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@3",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
